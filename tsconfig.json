{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"outDir": ".",
		"declaration": true,
		"declarationMap": true
	},
	"include": ["*.ts"],
	"exclude": ["node_modules", "dist"]
}
